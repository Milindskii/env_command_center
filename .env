# ──────────────────────────────────────────────
# Environmental Command Center — Configuration
# ──────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/env_command_center

# World Air Quality Index (WAQI) API token
# Get yours free at https://aqicn.org/data-platform/token/
AQI_API_KEY=your_api_key_here

# Comma-separated list of cities to monitor
MONITOR_CITIES=delhi,mumbai,bangalore,chennai,kolkata